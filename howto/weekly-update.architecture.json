    { "from": "ai", "to": "decide", "label": "verdict", "labelDy": -24 },
    { "from": "decide", "to": "apply", "label": "stale", "variant": "emphasis", "labelDy": -24 },
    { "from": "apply", "to": "pr", "label": "opens PR", "variant": "emphasis", "labelDy": -24 },
    { "from": "pr", "to": "kb", "label": "on merge", "variant": "dashed", "fromSide": "top", "toSide": "bottom" }
  ],
  "cards": [
    { "dot": "cyan", "title": "Gather", "items": ["lychee verifies every KB link", "RSS news, 7-day, keyword-filtered"] },
    { "dot": "emerald", "title": "Review + decide", "items": ["GPT-5 reviews the full KB + decision tree", "PR if broken links OR needsUpdate"] },
    { "dot": "amber", "title": "Human in the loop", "items": ["apply-update bumps version + changelog", "A human reviews and merges the PR"] }
