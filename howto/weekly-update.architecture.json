    { "id": "decide", "type": "backend", "label": "decide.mjs", "sublabel": "stale?", "pos": [680, 300], "size": [150, 60] },
    { "id": "apply", "type": "backend", "label": "apply-update.mjs", "sublabel": "bump + changelog", "pos": [890, 300], "size": [185, 60] },
    { "id": "kb", "type": "database", "label": "Knowledge base", "sublabel": "source of truth", "pos": [1135, 140], "size": [160, 60] },
    { "id": "pr", "type": "external", "label": "Pull request", "sublabel": "human merges", "pos": [1135, 300], "size": [160, 60], "tag": "kb-update" }
